---
interface Props {
  badge: string;
  title: string;
  subtitle: string;
  image: string;
  ctaPrimary: string;
  ctaSecondary: string;
  bookingUrl: string;
}

const { badge, title, subtitle, image, ctaPrimary, ctaSecondary, bookingUrl } = Astro.props;
---

<section class="relative isolate overflow-hidden">
  <img src={image} alt={title} class="h-[68vh] w-full object-cover" />
  <div class="absolute inset-0 bg-gradient-to-r from-[--color-text]/65 to-[--color-text]/25"></div>
  <div class="absolute inset-0 flex items-end">
    <div class="container-site pb-10 md:pb-16">
      <div class="max-w-2xl text-white">
        <p class="inline-block rounded-full bg-white/20 px-3 py-1 text-sm backdrop-blur">{badge}</p>
        <h1 class="mt-4 font-serif text-4xl leading-tight sm:text-5xl md:text-6xl">{title}</h1>
        <p class="mt-4 text-base text-white/90 sm:text-lg">{subtitle}</p>
        <div class="mt-8 flex flex-wrap gap-3">
          <a href={bookingUrl} class="btn-primary">
            {ctaPrimary}
          </a>
          <a href="/galeria" class="inline-flex items-center justify-center rounded-xl border border-white/70 px-5 py-3 text-sm font-semibold text-white transition-colors hover:bg-white/10 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-white/80">
            {ctaSecondary}
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
