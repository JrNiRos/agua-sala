---
interface Props {
  lang?: "es" | "en" | "fr";
}

const { lang = "es" } = Astro.props;
const isEs = lang === "es";
const base = isEs ? "" : `/${lang}`;

const labels = {
  es: {
    home: "Inicio",
    house: "La casa",
    area: "Entorno",
    gallery: "Galeria",
    location: "Ubicacion",
    contact: "Reservas",
    cta: "Consultar disponibilidad",
  },
  en: {
    home: "Home",
    house: "The House",
    area: "Area",
    gallery: "Gallery",
    location: "Location",
    contact: "Bookings",
    cta: "Check availability",
  },
  fr: {
    home: "Accueil",
    house: "La Maison",
    area: "Environs",
    gallery: "Galerie",
    location: "Localisation",
    contact: "Reservations",
    cta: "Verifier disponibilite",
  },
}[lang];
---

<header class="sticky top-0 z-40 border-b border-[--color-border] bg-[--color-bg]/90 backdrop-blur">
  <div class="container-site flex items-center justify-between py-3">
    <a href={base || "/"} class="font-serif text-xl font-semibold tracking-tight text-[--color-brand-700]">
      Agua Sala
    </a>

    <nav class="hidden items-center gap-5 text-sm md:flex">
      <a class="link-soft" href={`${base}/`}>{labels.home}</a>
      <a class="link-soft" href="/la-casa">{labels.house}</a>
      <a class="link-soft" href="/entorno">{labels.area}</a>
      <a class="link-soft" href="/galeria">{labels.gallery}</a>
      <a class="link-soft" href="/ubicacion">{labels.location}</a>
      <a class="btn-primary px-4 py-2" href="/reservas">
        {labels.cta}
      </a>
    </nav>

    <div class="flex items-center gap-2 text-xs font-medium">
      <a class={`rounded-md px-2 py-1 transition-colors ${lang === "es" ? "bg-[--color-brand-700] text-white" : "bg-[--color-surface-soft] text-[--color-text-muted] hover:bg-[--color-brand-100]"}`} href="/">ES</a>
      <a class={`rounded-md px-2 py-1 transition-colors ${lang === "en" ? "bg-[--color-brand-700] text-white" : "bg-[--color-surface-soft] text-[--color-text-muted] hover:bg-[--color-brand-100]"}`} href="/en">EN</a>
      <a class={`rounded-md px-2 py-1 transition-colors ${lang === "fr" ? "bg-[--color-brand-700] text-white" : "bg-[--color-surface-soft] text-[--color-text-muted] hover:bg-[--color-brand-100]"}`} href="/fr">FR</a>
    </div>
  </div>
</header>
