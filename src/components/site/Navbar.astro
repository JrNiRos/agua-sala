---
interface Props {
  lang?: "es" | "en" | "fr";
}

const { lang = "es" } = Astro.props;
const isEs = lang === "es";
const base = isEs ? "" : `/${lang}`;

const labels = {
  es: {
    home: "Inicio",
    house: "La casa",
    area: "Entorno",
    gallery: "Galeria",
    location: "Ubicacion",
    contact: "Reservas",
    cta: "Consultar disponibilidad",
  },
  en: {
    home: "Home",
    house: "The House",
    area: "Area",
    gallery: "Gallery",
    location: "Location",
    contact: "Bookings",
    cta: "Check availability",
  },
  fr: {
    home: "Accueil",
    house: "La Maison",
    area: "Environs",
    gallery: "Galerie",
    location: "Localisation",
    contact: "Reservations",
    cta: "Verifier disponibilite",
  },
}[lang];
---

<header class="sticky top-0 z-40 border-b border-[--color-border] bg-[--color-bg]/90 backdrop-blur">
  <div class="container-site flex items-center justify-between py-3">
    <a href={base || "/"} class="font-serif logo-font text-xl font-semibold tracking-tight text-[--color-brand-700]">
      El agua salá
    </a>

    <nav class="hidden items-center gap-5 text-sm md:flex">
      <a class="link-soft" href={`${base}/`}>{labels.home}</a>
      <a class="link-soft" href={`${base}/la-casa`}>{labels.house}</a>
      <a class="link-soft" href={`${base}/entorno`}>{labels.area}</a>
      <a class="link-soft" href={`${base}/galeria`}>{labels.gallery}</a>
      <a class="link-soft" href={`${base}/ubicacion`}>{labels.location}</a>
      <a class="btn-primary px-4 py-2" href={`${base}/reservas`}>
        {labels.cta}
      </a>
    </nav>

    <button id="menu-toggle" class="md:hidden p-2 text-[--color-text]" aria-label="Toggle menu">
      <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
      </svg>
    </button>

    <div class="flex items-center gap-2 text-xs font-medium">
      <a class={`rounded-md px-2 py-1 transition-colors ${lang === "es" ? "bg-white text-[--color-brand-700] border border-[--color-brand-700]" : "bg-[--color-surface-soft] text-[--color-text-muted] hover:bg-[--color-brand-100]"}`} href="/">ES</a>
      <a class={`rounded-md px-2 py-1 transition-colors ${lang === "en" ? "bg-white text-[--color-brand-700] border border-[--color-brand-700]" : "bg-[--color-surface-soft] text-[--color-text-muted] hover:bg-[--color-brand-100]"}`} href="/en">EN</a>
      <a class={`rounded-md px-2 py-1 transition-colors ${lang === "fr" ? "bg-white text-[--color-brand-700] border border-[--color-brand-700]" : "bg-[--color-surface-soft] text-[--color-text-muted] hover:bg-[--color-brand-100]"}`} href="/fr">FR</a>
    </div>
  </div>

  <div id="mobile-menu" class="hidden absolute top-full left-0 right-0 bg-white border-b border-[--color-border] shadow-lg md:hidden">
    <div class="container-site py-4 flex flex-col gap-4">
      <a class="link-soft text-[--color-text]" href={`${base}/`}>{labels.home}</a>
      <a class="link-soft text-[--color-text]" href={`${base}/la-casa`}>{labels.house}</a>
      <a class="link-soft text-[--color-text]" href={`${base}/entorno`}>{labels.area}</a>
      <a class="link-soft text-[--color-text]" href={`${base}/galeria`}>{labels.gallery}</a>
      <a class="link-soft text-[--color-text]" href={`${base}/ubicacion`}>{labels.location}</a>
      <a class="btn-primary px-4 py-2 w-fit" href={`${base}/reservas`}>
        {labels.cta}
      </a>
    </div>
  </div>
</header>

<script client:load>
  document.getElementById('menu-toggle').addEventListener('click', () => {
    const menu = document.getElementById('mobile-menu');
    menu.classList.toggle('hidden');
  });
</script>

