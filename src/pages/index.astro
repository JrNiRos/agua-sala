---
import Layout from "../layouts/Layout.astro";
import Hero from "../components/home/Hero.astro";
---

<Layout
  title="Casa rural en Villanueva del Rio y Minas | Agua Sala"
  description="Casa rural para hasta 7 huespedes en Sevilla. Vistas, naturaleza, Munigua y escapadas con encanto cerca de la ciudad."
>
  <Hero
    badge="Casa rural para hasta 7 huespedes"
    title="Tu refugio rural en Villanueva del Rio y Minas"
    subtitle="Desconecta entre vistas abiertas, naturaleza y experiencias autenticas. Perfecta para familias, amigos y viajeros internacionales."
    image="/images/patio-2.png"
    ctaPrimary="Consultar disponibilidad"
    ctaSecondary="Ver galeria"
    bookingUrl="/reservas"
  />

  <section class="section-pad bg-[--color-brand-50]">
    <div class="container-site">
      <h2 class="font-serif text-3xl text-[--color-text] md:text-4xl">Por que elegir Agua Sala</h2>
      <div class="mt-10 grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
        <article class="card-soft p-6 transition-shadow hover:shadow-md">
          <h3 class="font-semibold text-[--color-text]">Hasta 7 huespedes</h3>
          <p class="mt-2 text-sm text-[--color-text-muted]">Espacio comodo para familias y grupos de amigos.</p>
        </article>
        <article class="card-soft p-6 transition-shadow hover:shadow-md">
          <h3 class="font-semibold text-[--color-text]">Vistas y calma</h3>
          <p class="mt-2 text-sm text-[--color-text-muted]">Ambiente acogedor para desconectar del ritmo diario.</p>
        </article>
        <article class="card-soft p-6 transition-shadow hover:shadow-md">
          <h3 class="font-semibold text-[--color-text]">Experiencias unicas</h3>
          <p class="mt-2 text-sm text-[--color-text-muted]">Muy cerca de Munigua, rutas y rincones naturales.</p>
        </article>
        <article class="card-soft p-6 transition-shadow hover:shadow-md">
          <h3 class="font-semibold text-[--color-text]">Cerca de Sevilla</h3>
          <p class="mt-2 text-sm text-[--color-text-muted]">La tranquilidad rural con acceso comodo a la ciudad.</p>
        </article>
      </div>
    </div>
  </section>

  <section class="section-pad">
    <div class="container-site grid items-center gap-10 lg:grid-cols-2">
      <div>
        <p class="text-sm font-semibold uppercase tracking-wide text-[--color-brand-700]">Entorno</p>
        <h2 class="mt-2 font-serif text-3xl text-[--color-text] md:text-4xl">Naturaleza, historia y planes de calidad</h2>
        <p class="mt-4 text-[--color-text-muted]">
          Descubre el yacimiento romano de Munigua, pasea por la ribera y disfruta paisajes que
          invitan a bajar el ritmo. La ubicacion permite combinar relax y escapadas culturales.
        </p>
        <a href="/entorno" class="btn-primary mt-6">
          Explorar entorno
        </a>
      </div>
      <img
        src="/images/paisaje-1.png"
        alt="Paisaje y entorno cercano a la casa"
        class="h-[360px] w-full rounded-3xl object-cover shadow-sm ring-1 ring-[--color-border]"
      />
    </div>
  </section>

  <section class="pb-14 md:pb-20">
    <div class="container-site">
      <div class="rounded-3xl bg-[#3f78a8] p-8 text-white md:p-12">
        <h2 class="font-serif text-3xl text-white md:text-4xl">Las mejores fechas se reservan rapido</h2>
        <p class="mt-3 max-w-2xl text-white">
          Escribenos y te ayudamos a organizar una estancia inolvidable en Villanueva del Rio y Minas.
        </p>
        <div class="mt-6 flex flex-wrap gap-3">
          <a href="/reservas" class="inline-flex items-center justify-center rounded-xl bg-[#fceedd] px-6 py-3 font-semibold text-[#2f3a33] transition-colors hover:bg-[#f2cfab] focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-white/80">
            Reservar ahora
          </a>
          <a href="https://wa.me/34620880212" class="inline-flex items-center justify-center rounded-xl border border-white/40 px-6 py-3 font-semibold transition-colors hover:bg-white/10 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-white/80">
            WhatsApp directo
          </a>
        </div>
      </div>
    </div>
  </section>
</Layout>
