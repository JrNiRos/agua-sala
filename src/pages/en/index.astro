---
import Layout from "../../layouts/Layout.astro";
import Hero from "../../components/home/Hero.astro";
---

<Layout
  lang="en"
  title="Rural house near Seville | Agua Sala"
  description="Charming rural house for up to 7 guests in Villanueva del Rio y Minas, Seville."
>
  <Hero
    badge="Rural house for up to 7 guests"
    title="Your countryside stay near Seville"
    subtitle="Enjoy views, nature and local experiences close to Munigua and beautiful river landscapes."
    image="/images/patio-2.png"
    ctaPrimary="Check availability"
    ctaSecondary="View gallery"
    bookingUrl="/reservas"
  />
  <section class="container-site py-16">
    <h2 class="font-serif text-3xl text-stone-900">Warm, comfortable and authentic</h2>
    <p class="mt-4 max-w-3xl text-stone-600">
      This multilingual version is ready and can be expanded page by page. Contact us for your dates.
    </p>
  </section>
</Layout>
