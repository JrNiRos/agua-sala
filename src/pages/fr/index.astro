---
import Layout from "../../layouts/Layout.astro";
import Hero from "../../components/home/Hero.astro";
---

<Layout
  lang="fr"
  title="Maison rurale pres de Seville | Agua Sala Rural"
  description="Maison rurale chaleureuse pour 7 personnes a Villanueva del Rio y Minas."
>
  <Hero
    badge="Maison rurale pour 7 personnes"
    title="Votre sejour nature pres de Seville"
    subtitle="Profitez des vues, de la nature et des experiences locales, proche de Munigua."
    image="/images/patio-2.png"
    ctaPrimary="Verifier disponibilite"
    ctaSecondary="Voir galerie"
    bookingUrl="/reservas"
  />
  <section class="container-site py-16">
    <h2 class="font-serif text-3xl text-stone-900">Confort et authenticite</h2>
    <p class="mt-4 max-w-3xl text-stone-600">
      Cette version multilingue est prete et peut etre etendue page par page selon vos besoins.
    </p>
  </section>
</Layout>
